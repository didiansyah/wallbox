# Wallbox Environment Example

# Tatum
TATUM_API_KEY=
TATUM_SUI_RPC_URL=
SUI_NETWORK=testnet

# Sui wallet / package
SUI_PRIVATE_KEY=
SUI_PACKAGE_ID=
SUI_CERTIFICATE_MODULE=certificate

# Walrus
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=
WALRUS_NETWORK=testnet

# Safety
# Mainnet is disabled by default. Keep testnet for hackathon/production demo until funds + ops are ready.
WALLBOX_ALLOW_MAINNET=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3070
WALLBOX_STORAGE_DIR=./data/runs

# External capture API
# Required in production for POST /api/runs when mode=external. Supports x-wallbox-api-key or Authorization: Bearer.
WALLBOX_API_KEY=
# Optional comma-separated rotation list. If both are set, all keys are accepted.
WALLBOX_API_KEYS=

# Demo/integration modes
# local = hackathon-safe fallback; walrus/sui-tatum = real integrations once credentials and package are ready
WALLBOX_BLOB_STORE_MODE=local
WALLBOX_CERTIFICATE_MODE=local
