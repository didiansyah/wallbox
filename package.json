{
  "name": "wallbox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3070",
    "build": "next build",
    "build:sdk": "pnpm --filter @wallbox/sdk build",
    "build:mcp": "pnpm --filter @wallbox/mcp-server build",
    "build:all": "pnpm build:sdk && pnpm build:mcp && pnpm build",
    "start": "next start -p 3070",
    "lint": "next lint",
    "test": "vitest run"
  },
  "dependencies": {
    "@tailwindcss/postcss": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "lucide-react": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
